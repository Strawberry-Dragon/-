.container {
  padding: 40rpx 30rpx;
  background-color: #FFF7FA;
  min-height: 100vh;
}

.status-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 50rpx 30rpx;
  margin-bottom: 50rpx;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
  text-align: center;
  margin-bottom: 30rpx;
  color: #333;
}

.state-line {
  font-size: 28rpx;
  text-align: center;
}

.agree-text {
  color: #39b54a;
  font-weight: bold;
}

.disagree-text {
  color: #ff5577;
  font-weight: bold;
}

/* 基础按钮样式：淡粉色背景、白色字体 */
.btn {
  background-color: #FFD6E0;
  color: #ffffff;
  font-size: 28rpx;
  border: none;
  border-radius: 50rpx;
  margin: 20rpx 0;
}
/* 去除小程序默认按钮边框 */
.btn::after {
  border: none;
}

/* 撤回按钮微调（浅一点的粉色区分） */
.btn.reset {
  background-color: #FFE3EC;
}

/* 返回按钮底部留白加大 */
.btn.back {
  margin-top: 80rpx;
  background-color: #FFC8D8;
}