.label {
  font-size: 30rpx;
  color: #555;
  margin-bottom: 20rpx;
}
.title-input {
  font-size: 30rpx;
}
.content-input {
  min-height: 220rpx;
  font-size: 28rpx;
}
.img-box {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.img-item {
  width: 160rpx;
  height: 160rpx;
  position: relative;
}
.pic {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}
.del-icon {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 40rpx;
  height: 40rpx;
  background: #ff6b81;
  color: #fff;
  text-align: center;
  line-height: 40rpx;
  border-radius: 50%;
  font-size: 28rpx;
}
.add-pic-btn {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed #FFC8D8;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  color: #FFB6C8;
}
.save-btn {
  margin-top: 40rpx;
  height: 90rpx;
  font-size: 32rpx;
}
