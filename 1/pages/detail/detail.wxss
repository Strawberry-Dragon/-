/* pages/detail/detail.wxss */
.detail-time {
  font-size: 26rpx;
  color: #c88899;
  margin-bottom: 20rpx;
}
.detail-title {
  font-size: 38rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 30rpx;
}
.detail-content {
  font-size: 30rpx;
  line-height: 1.8;
  color: #444;
  margin-bottom: 40rpx;
}
.img-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
.img-item {
  width: 200rpx;
  height: 200rpx;
}
.pic {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}
.del-btn {
  margin-top: 50rpx;
  color: #ff5577;
  border: 1rpx solid #ffb6c8;
  background: #fff;
  border-radius: 50rpx;
}
.del-btn::after {
  border: none;
}