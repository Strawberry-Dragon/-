page {
  background-color: #FFF7FA;
  font-family: "PingFang SC", "微软雅黑";
  padding: 20rpx;
  box-sizing: border-box;
}

/* 通用圆角卡片 */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 15rpx rgba(255, 180, 200, 0.15);
  margin-bottom: 25rpx;
}

/* 可爱粉色按钮通用样式 */
.btn-pink {
  background-color: #FFB6C8;
  color: #fff;
  border-radius: 50rpx;
  border: none;
  font-size: 30rpx;
}
.btn-pink::after {
  border: none;
}

/* 输入框统一样式 */
.input-box {
  border: 1rpx solid #FFD6E0;
  border-radius: 16rpx;
  padding: 25rpx;
  background: #fff;
}